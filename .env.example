# ============================================================================
# EduCare Exam Prep Studio — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development.
# For production, set these in Vercel Environment Variables settings.
# ============================================================================

# ─── Frontend (Vite) ────────────────────────────────────────────────────
# These are embedded in the client bundle — never put secrets here.
# Set in: Vercel → Project Settings → Environment Variables

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe price IDs (public, used by ExamPrepUpgrade.tsx to start checkout)
VITE_STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxx
VITE_STRIPE_BIANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxx

# ─── Supabase Edge Function Secrets ─────────────────────────────────────
# These are NOT set in Vercel. Set via: supabase secrets set KEY=value
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are auto-set.

# GEMINI_API_KEY=your-gemini-api-key
# STRIPE_SECRET_KEY=sk_test_... (or sk_live_... for production)
# STRIPE_WEBHOOK_SECRET=whsec_...
